{
	"format_version": "1.19.0",
	"animation_controllers": {
		"controller.animation.gluon_gun.firstPerson": {
			"initial_state": "fp_select_gate",
			"states": {
				"fp_select_gate": {
					"transitions": [
						{
							"fp_draw_admire": "math.random(0.0, 1.0) < 0.25"
						},
						{
							"fp_draw": "1.0"
						}
					]
				},
				"fp_draw_admire": {
					"animations": [
						"fp_draw_admire"
					],
					"transitions": [
						{
							"fp_idle": "query.any_animation_finished"
						}
					]
				},
				"fp_draw": {
					"animations": [
						"fp_draw"
					],
					"transitions": [
						{
							"fp_fire": "query.is_using_item"
						},
						{
							"fp_idle": "query.any_animation_finished"
						}
					]
				},
				"fp_idle": {
					"animations": [
						"fp_idle"
					],
					"transitions": [
						{
							"fp_fire": "query.is_using_item"
						},
						{
							"fp_idle_fidget": "query.anim_time >= 10.0 && math.random(0.0, 1.0) < 0.001"
						}
					]
				},
				"fp_idle_fidget": {
					"animations": [
						"fp_idle_fidget"
					],
					"transitions": [
						{
							"fp_fire": "query.is_using_item"
						},
						{
							"fp_idle": "query.any_animation_finished"
						}
					]
				},
				"fp_fire": {
					"animations": [
						"fp_fire"
					],
					"transitions": [
						{
							"fp_fire_end": "!query.is_using_item"
						}
					]
				},
				"fp_fire_end": {
					"animations": [
						"fp_fire_end"
					],
					"transitions": [
						{
							"fp_idle": "query.any_animation_finished"
						}
					]
				}
			}
		},
		"controller.animation.gluon_gun.thirdPerson": {
			"initial_state": "tp_select_gate",
			"states": {
				"tp_select_gate": {
					"transitions": [
						{
							"tp_draw_admire": "math.random(0.0, 1.0) < 0.25"
						},
						{
							"tp_draw": "1.0"
						}
					]
				},
				"tp_draw_admire": {
					"animations": [
						"tp_draw_admire"
					],
					"transitions": [
						{
							"tp_idle": "query.any_animation_finished"
						}
					]
				},
				"tp_draw": {
					"animations": [
						"tp_draw"
					],
					"transitions": [
						{
							"tp_fire": "query.is_using_item"
						},
						{
							"tp_idle": "query.any_animation_finished"
						}
					]
				},
				"tp_idle": {
					"animations": [
						"tp_idle"
					],
					"transitions": [
						{
							"tp_fire": "query.is_using_item"
						},
						{
							"tp_idle_fidget": "query.anim_time >= 10.0 && math.random(0.0, 1.0) < 0.001"
						}
					]
				},
				"tp_idle_fidget": {
					"animations": [
						"tp_idle_fidget"
					],
					"transitions": [
						{
							"tp_fire": "query.is_using_item"
						},
						{
							"tp_idle": "query.any_animation_finished"
						}
					]
				},
				"tp_fire": {
					"animations": [
						"tp_fire"
					],
					"transitions": [
						{
							"tp_fire_end": "!query.is_using_item"
						}
					]
				},
				"tp_fire_end": {
					"animations": [
						"tp_fire_end"
					],
					"transitions": [
						{
							"tp_idle": "query.any_animation_finished"
						}
					]
				}
			}
		}
	}
}