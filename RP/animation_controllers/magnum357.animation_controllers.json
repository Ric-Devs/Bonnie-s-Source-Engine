{
  "format_version": "1.19.0",
  "animation_controllers": {
    "controller.animation.magnum357.firstPerson": {
      "initial_state": "fp_select_gate",
      "states": {
        "fp_select_gate": {
          "transitions": [
            {
              "fp_draw_admire": "math.random(0.0, 1.0) < 0.12"
            },
            {
              "fp_draw": "1.0"
            }
          ]
        },
        "fp_draw_admire": {
          "animations": [
            "fp_draw_admire"
          ],
          "transitions": [
            {
              "fp_idle_to_centerfire": "query.any_animation_finished && query.is_sneaking"
            },
            {
              "fp_idle": "query.any_animation_finished"
            }
          ]
        },
        "fp_draw": {
          "animations": [
            "fp_draw"
          ],
          "transitions": [
            {
              "fp_fire_gate": "query.is_using_item && !query.is_sneaking && query.item_in_use_duration <= 1.0"
            },
            {
              "fp_idle_to_centerfire": "query.any_animation_finished && query.is_sneaking"
            },
            {
              "fp_reload": "query.is_using_item && query.item_in_use_duration > 1.0"
            },
            {
              "fp_idle": "query.any_animation_finished"
            }
          ]
        },
        "fp_idle": {
          "animations": [
            "fp_idle"
          ],
          "transitions": [
            {
              "fp_fire_gate": "query.is_using_item && !query.is_sneaking && query.item_in_use_duration <= 1.0"
            },
            {
              "fp_idle_to_centerfire": "query.is_sneaking"
            },
            {
              "fp_reload": "query.is_using_item && query.item_in_use_duration > 1.0"
            },
            {
              "fp_idle_fidget": "query.anim_time >= 10.0 && math.random(0.0, 1.0) < 0.001"
            }
          ]
        },
        "fp_idle_fidget": {
          "animations": [
            "fp_idle_fidget"
          ],
          "transitions": [
            {
              "fp_fire_gate": "query.is_using_item && !query.is_sneaking && query.item_in_use_duration <= 1.0"
            },
            {
              "fp_idle_to_centerfire": "query.is_sneaking"
            },
            {
              "fp_reload": "query.is_using_item && query.item_in_use_duration > 1.0"
            },
            {
              "fp_idle": "query.any_animation_finished"
            }
          ]
        },
        "fp_fire_gate": {
          "transitions": [
            {
              "fp_fire1": "math.random(0.0, 1.0) < 0.5"
            },
            {
              "fp_fire2": "1.0"
            }
          ]
        },
        "fp_fire1": {
          "animations": [
            "fp_fire1"
          ],
          "transitions": [
            {
              "fp_idle_to_centerfire": "query.any_animation_finished && query.is_sneaking"
            },
            {
              "fp_idle": "query.any_animation_finished"
            }
          ]
        },
        "fp_fire2": {
          "animations": [
            "fp_fire2"
          ],
          "transitions": [
            {
              "fp_idle_to_centerfire": "query.any_animation_finished && query.is_sneaking"
            },
            {
              "fp_idle": "query.any_animation_finished"
            }
          ]
        },
        "fp_idle_to_centerfire": {
          "animations": [
            "fp_idle_to_centerfire"
          ],
          "transitions": [
            {
              "fp_centerfire_idle": "query.any_animation_finished"
            }
          ]
        },
        "fp_centerfire_idle": {
          "animations": [
            "fp_centerfire_idle"
          ],
          "transitions": [
            {
              "fp_centerfire_fire_gate": "query.is_using_item && query.is_sneaking && query.item_in_use_duration <= 1.0"
            },
            {
              "fp_centerfire_to_idle": "!query.is_sneaking"
            },
            {
              "fp_reload": "query.is_using_item && query.item_in_use_duration > 1.0"
            }
          ]
        },
        "fp_centerfire_fire_gate": {
          "transitions": [
            {
              "fp_centerfire1": "math.random(0.0, 1.0) < 0.5"
            },
            {
              "fp_centerfire2": "1.0"
            }
          ]
        },
        "fp_centerfire1": {
          "animations": [
            "fp_centerfire1"
          ],
          "transitions": [
            {
              "fp_reload": "query.is_using_item && query.item_in_use_duration > 1.0"
            },
            {
              "fp_centerfire_to_idle": "query.any_animation_finished && !query.is_sneaking"
            },
            {
              "fp_centerfire_idle": "query.any_animation_finished"
            }
          ]
        },
        "fp_centerfire2": {
          "animations": [
            "fp_centerfire2"
          ],
          "transitions": [
            {
              "fp_reload": "query.is_using_item && query.item_in_use_duration > 1.0"
            },
            {
              "fp_centerfire_to_idle": "query.any_animation_finished && !query.is_sneaking"
            },
            {
              "fp_centerfire_idle": "query.any_animation_finished"
            }
          ]
        },
        "fp_centerfire_to_idle": {
          "animations": [
            "fp_centerfire_to_idle"
          ],
          "transitions": [
            {
              "fp_idle": "query.any_animation_finished"
            }
          ]
        },
        "fp_reload": {
