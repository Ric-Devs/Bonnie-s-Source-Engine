        "tp_egon_idle": "animation.gluon_gun.idle2",
        "tp_egon_draw_admire": "animation.gluon_gun.draw_admire2",
        "tp_egon_draw": "animation.gluon_gun.draw2",
        "tp_egon_idle_fidget": "animation.gluon_gun.idle_fidget_tp",
        "tp_egon_fire": "animation.gluon_gun.fire2",
        "tp_egon_fire_end": "animation.gluon_gun.fire_end_tp",
        "gluon_gun_tp_arm_isolation": "animation.gluon_gun.hold_tp",
        "gluon_gun_tp_controller": "controller.animation.player.gluon_gun_tp"
      },
      "render_controllers": [
        {
          "controller.render.player.first_person_spectator": "variable.is_first_person && query.is_spectator"
        },
        {
          "controller.render.player.third_person_spectator": "!variable.is_first_person && !variable.map_face_icon && query.is_spectator"
        },
        {
          "controller.render.player.first_person": "variable.is_first_person && !query.is_spectator"
        },
        {
          "controller.render.player.third_person": "!variable.is_first_person && !variable.map_face_icon && !query.is_spectator"
        },
        {
          "controller.render.player.map": "variable.map_face_icon"
        }
      ],
      "enable_attachables": true
    }
  }
}