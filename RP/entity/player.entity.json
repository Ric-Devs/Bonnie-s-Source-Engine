        "pre_animation": [
          "variable.helmet_layer_visible = !query.has_head_gear;",
          "variable.leg_layer_visible = 1.0;",
          "variable.boot_layer_visible = 1.0;",
          "variable.chest_layer_visible = 1.0;",
          "variable.attack_body_rot_y = Math.sin(360*Math.sqrt(variable.attack_time)) * 5.0;",
          "variable.tcos0 = (math.cos(query.modified_distance_moved * 38.17) * query.modified_move_speed / variable.gliding_speed_value) * 57.3;",
          "variable.first_person_item_rotation_factor = math.sin((1 - variable.attack_time) * 180.0);",
          "variable.hand_bob = query.life_time < 0.01 ? 0.0 : variable.hand_bob + ((query.is_on_ground && query.is_alive ? math.clamp(math.sqrt(math.pow(query.position_delta(0), 2.0) + math.pow(query.position_delta(2), 2.0)), 0.0, 0.1) : 0.0) - variable.hand_bob) * 0.02;",
          "variable.map_angle = math.clamp(1 - variable.player_x_rotation / 45.1, 0.0, 1.0);",
          "variable.item_use_duration = query.main_hand_item_use_duration > 0.0 ? (query.main_hand_item_max_duration - (query.main_hand_item_use_duration - query.frame_alpha + 1.0)) : 0.0;",
          "variable.item_use_normalized = query.main_hand_item_use_duration / query.main_hand_item_max_duration;",
          "variable.riding_y_offset = query.is_riding_any_entity_of_type('minecraft:minecart', 'minecraft:boat', 'minecraft:chest_boat', 'minecraft:strider') ? -3.0 : 0.0;",
          "variable.melee_spear_equipped = query.equipped_item_any_tag('slot.weapon.mainhand', 'minecraft:is_spear');",
          "variable.tp_melee_spear_base_arm_rotation_x = (query.is_swimming || query.is_gliding) ? (-115.0 - query.target_x_rotation) : (query.is_crawling ? -115.0 : -30.0);",
          "variable.tp_melee_spear_use_arm_rotation_x = 0.0;",
          "variable.tp_melee_spear_use_arm_rotation_y = 0.0;",
          "variable.tp_melee_spear_use_arm_rotation_z = 0.0;",
          "variable.tp_melee_spear_use_item_rotation_x = 0.0;",
          "variable.tp_melee_spear_use_attachable_rotation_z = 0.0;",
          "variable.fp_melee_spear_use_item_position_x = 0.0;",
          "variable.fp_melee_spear_use_item_position_y = 0.0;",
          "variable.fp_melee_spear_use_item_position_z = 0.0;",
          "variable.fp_melee_spear_use_item_rotation_y = 0.0;",
          "variable.fp_melee_spear_use_item_rotation_z = 0.0;",
          "variable.fp_melee_spear_use_attachable_rotation_z = 0.0;",
          "variable.fp_melee_spear_attack_item_position_x = 0.0;",
          "variable.fp_melee_spear_attack_item_position_y = 0.0;",
          "variable.fp_melee_spear_attack_item_position_z = 0.0;",
          "variable.fp_melee_spear_attack_item_rotation_y = 0.0;",
          "variable.fp_melee_spear_attack_item_rotation_z = 0.0;",
          "variable.fp_melee_spear_attack_attachable_rotation_z = 0.0;",
          "variable.tp_melee_spear_attack_arm_rotation_x = 0.0;",
          "variable.tp_melee_spear_attack_item_rotation_x = 0.0;",
          "variable.tp_melee_spear_attack_attachable_position_z = 0.0;",
          "  temp.melee_spear_use_finish_raise_tick = query.kinetic_weapon_delay;",
          "  temp.melee_spear_use_finish_sway_tick = temp.melee_spear_use_finish_raise_tick + query.kinetic_weapon_dismount_duration;",
          "  temp.melee_spear_use_start_sway_tick = temp.melee_spear_use_finish_sway_tick - 20.0;",
          "  temp.melee_spear_use_finish_lower_tick = temp.melee_spear_use_finish_raise_tick + query.kinetic_weapon_knockback_duration;",
          "  temp.melee_spear_use_start_lower_tick = temp.melee_spear_use_finish_lower_tick - 40.0;",
          "  temp.melee_spear_use_finish_raise_back_tick = temp.melee_spear_use_finish_raise_tick + query.kinetic_weapon_damage_duration;",
          "  temp.melee_spear_use_start_raise_back_tick = temp.melee_spear_use_finish_raise_back_tick - 5.0;",
          "  temp.melee_spear_use_raise_progress = math.clamp(math.inverse_lerp(0.0, temp.melee_spear_use_finish_raise_tick, variable.item_use_duration), 0.0, 1.0);",
          "  temp.melee_spear_use_raise_progress_start = math.clamp(math.inverse_lerp(0.0, 0.5, temp.melee_spear_use_raise_progress), 0.0, 1.0);",
          "  temp.melee_spear_use_raise_progress_middle = math.clamp(math.inverse_lerp(0.5, 0.8, temp.melee_spear_use_raise_progress), 0.0, 1.0);",
          "  temp.melee_spear_use_raise_progress_end = math.clamp(math.inverse_lerp(0.8, 1.0, temp.melee_spear_use_raise_progress), 0.0, 1.0);",
          "  temp.melee_spear_use_sway_progress = math.clamp(math.inverse_lerp(temp.melee_spear_use_start_sway_tick, temp.melee_spear_use_finish_sway_tick, variable.item_use_duration), 0.0, 1.0);",
          "  temp.melee_spear_use_lower_progress = math.ease_in_out_elastic(0.0, 1.0, math.clamp(math.inverse_lerp(temp.melee_spear_use_start_lower_tick, temp.melee_spear_use_finish_lower_tick, variable.item_use_duration - 20.0), 0.0, 1.0));",
          "  temp.melee_spear_use_raise_back_progress = math.clamp(math.inverse_lerp(temp.melee_spear_use_start_raise_back_tick, temp.melee_spear_use_finish_raise_back_tick, variable.item_use_duration), 0.0, 1.0);",
          "  temp.melee_spear_use_sway_intensity = math.ease_out_circ(0.0, 2.0, temp.melee_spear_use_sway_progress) + math.ease_in_circ(0.0, -2.0, temp.melee_spear_use_raise_back_progress);",
          "  temp.melee_spear_use_sway_scale_slow = math.sin(variable.item_use_duration * 19.0) * temp.melee_spear_use_sway_intensity;",
          "  temp.melee_spear_use_sway_scale_fast = math.sin(variable.item_use_duration * 30.0) * temp.melee_spear_use_sway_intensity;",
          "  variable.fp_melee_spear_use_item_position_x = (temp.melee_spear_use_raise_progress_start * 0.05 + temp.melee_spear_use_raise_progress_end * -0.05 + temp.melee_spear_use_sway_scale_slow * 0.005) * variable.melee_spear_java_to_bedrock_scale;",
          "  variable.fp_melee_spear_use_item_position_y = (temp.melee_spear_use_raise_progress_start * -0.075 + temp.melee_spear_use_raise_progress_middle * 0.075 + temp.melee_spear_use_sway_scale_fast * 0.01) * variable.melee_spear_java_to_bedrock_scale;",
          "  variable.fp_melee_spear_use_item_position_z = (temp.melee_spear_use_raise_progress_start * 0.05 + temp.melee_spear_use_raise_progress_end * -0.05 + temp.melee_spear_use_sway_scale_slow * 0.005) * variable.melee_spear_java_to_bedrock_scale;",
          "  variable.fp_melee_spear_use_item_rotation_y = temp.melee_spear_use_raise_progress * 20.0 + temp.melee_spear_use_lower_progress * 20.0 + temp.melee_spear_use_sway_scale_slow * 0.5 + temp.melee_spear_use_raise_back_progress * -40.0;",
          "  variable.fp_melee_spear_use_item_rotation_z = math.ease_in_out_back(0.0, -60.0, temp.melee_spear_use_raise_progress) + temp.melee_spear_use_lower_progress * -25.0 + temp.melee_spear_use_raise_back_progress * 85.0 + temp.melee_spear_use_sway_scale_fast * 0.5;",
          "  variable.fp_melee_spear_use_attachable_rotation_z = math.clamp(math.inverse_lerp(0.5, 0.55, temp.melee_spear_use_raise_progress), 0.0, 1.0) * -50.0 + temp.melee_spear_use_sway_progress * 90.0 + temp.melee_spear_use_raise_back_progress * -40.0;",
          "  variable.tp_melee_spear_use_arm_rotation_x = temp.melee_spear_use_raise_progress_start * -40.0 + temp.melee_spear_use_raise_progress_middle * 30.0 + temp.melee_spear_use_raise_progress_end * -20.0 + temp.melee_spear_use_lower_progress * 20.0 + temp.melee_spear_use_raise_back_progress * 10.0;",
          "  variable.tp_melee_spear_use_arm_rotation_x = variable.tp_melee_spear_use_arm_rotation_x + temp.melee_spear_use_sway_scale_slow * 0.6;",
          "  variable.tp_melee_spear_use_arm_rotation_y = temp.melee_spear_use_sway_scale_fast * 1.0;",
          "  variable.tp_melee_spear_use_arm_rotation_z = temp.melee_spear_use_sway_scale_slow * 0.5;",
          "  variable.tp_melee_spear_use_item_rotation_x = temp.melee_spear_use_raise_progress * 60.0 + temp.melee_spear_use_raise_back_progress * -60.0;",
          "  variable.tp_melee_spear_use_attachable_rotation_z = temp.melee_spear_use_raise_progress * 90.0 + temp.melee_spear_use_sway_progress * -90.0;",
          "  temp.melee_spear_attack_duration_ratio = 1.0 / query.base_swing_duration;",
          "  temp.melee_spear_attack_raise_end = 0.05 * temp.melee_spear_attack_duration_ratio;",
          "  temp.melee_spear_attack_thrust_end = 0.2 * temp.melee_spear_attack_duration_ratio;",
          "  temp.melee_spear_attack_recover_start = 1.0 - (0.6 * temp.melee_spear_attack_duration_ratio);",
          "  temp.melee_spear_attack_raise_progress = math.clamp(math.inverse_lerp(0.0, temp.melee_spear_attack_raise_end, variable.attack_time), 0.0, 1.0);",
          "  temp.melee_spear_attack_thrust_progress = math.clamp(math.inverse_lerp(temp.melee_spear_attack_raise_end, temp.melee_spear_attack_thrust_end, variable.attack_time), 0.0, 1.0);",
          "  temp.melee_spear_attack_recover_progress = math.clamp(math.inverse_lerp(temp.melee_spear_attack_recover_start, 1.0, variable.attack_time), 0.0, 1.0);",
          "  temp.melee_spear_attack_raise_scale = math.ease_in_out_sine(0.0, 1.0, temp.melee_spear_attack_raise_progress);",
          "  temp.melee_spear_attack_thrust_scale = math.ease_in_quad(0.0, 1.0, temp.melee_spear_attack_thrust_progress);",
          "  temp.melee_spear_attack_recover_scale = math.ease_in_out_expo(0.0, 1.0, temp.melee_spear_attack_recover_progress);",
          "  variable.fp_melee_spear_attack_item_position_x = (temp.melee_spear_attack_raise_scale * 0.1 + temp.melee_spear_attack_thrust_scale * -0.1) * variable.melee_spear_java_to_bedrock_scale;",
          "  variable.fp_melee_spear_attack_item_position_y = (temp.melee_spear_attack_raise_scale * -0.075 + temp.melee_spear_attack_recover_scale * 0.075) * variable.melee_spear_java_to_bedrock_scale;",
          "  variable.fp_melee_spear_attack_item_position_z = (temp.melee_spear_attack_raise_scale * 0.65 + temp.melee_spear_attack_thrust_scale * -0.65) * variable.melee_spear_java_to_bedrock_scale;",
          "  variable.fp_melee_spear_attack_item_rotation_y = temp.melee_spear_attack_raise_scale * 20.0 + temp.melee_spear_attack_recover_scale * -20.0;",
          "  variable.fp_melee_spear_attack_item_rotation_z = temp.melee_spear_attack_raise_scale * -60.0 + temp.melee_spear_attack_recover_scale * 60.0;",
          "  variable.fp_melee_spear_attack_attachable_rotation_z = temp.melee_spear_attack_raise_scale * 40.0 + temp.melee_spear_attack_recover_scale * -40.0;",
          "  variable.tp_melee_spear_attack_arm_rotation_x = temp.melee_spear_attack_raise_scale * 90.0 + temp.melee_spear_attack_thrust_scale * -120.0 + temp.melee_spear_attack_recover_scale * 30.0;",
          "  variable.tp_melee_spear_attack_item_rotation_x = temp.melee_spear_attack_thrust_scale * 60.0 + temp.melee_spear_attack_recover_scale * -60.0;",
          "  variable.tp_melee_spear_attack_attachable_position_z = (temp.melee_spear_attack_thrust_scale * -0.15 + temp.melee_spear_attack_recover_scale * 0.15) * variable.melee_spear_java_to_bedrock_scale;",
          "variable.is_holding_left = 0.0;",
          "variable.is_tooting_goat_horn = 0.0;",
          "variable.is_using_brush = 0.0;",
          "variable.gluon_gun_equipped = query.equipped_item_any_tag('slot.weapon.mainhand', 'brr:gluon_gun');",
          "variable.items = variable.gluon_gun_equipped;"
        ],
